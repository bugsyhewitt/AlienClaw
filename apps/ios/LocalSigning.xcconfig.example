// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

ALIENCLAW_CODE_SIGN_STYLE = Automatic
ALIENCLAW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

ALIENCLAW_APP_BUNDLE_ID = ai.alienclaw.client
ALIENCLAW_SHARE_BUNDLE_ID = ai.alienclaw.client.share
ALIENCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.alienclaw.client.activitywidget
ALIENCLAW_WATCH_APP_BUNDLE_ID = ai.alienclaw.client.watchkitapp
ALIENCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.alienclaw.client.watchkitapp.extension

// Leave empty with automatic signing.
ALIENCLAW_APP_PROFILE =
ALIENCLAW_SHARE_PROFILE =
