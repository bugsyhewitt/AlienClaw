# AlienClaw gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into alienclaw's ~/.config/containers/systemd/
# {{ALIENCLAW_HOME}} is replaced at install time.

[Unit]
Description=AlienClaw gateway (rootless Podman)

[Container]
Image=alienclaw:local
ContainerName=alienclaw
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{ALIENCLAW_HOME}}/.alienclaw:/home/node/.alienclaw
EnvironmentFile={{ALIENCLAW_HOME}}/.alienclaw/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
